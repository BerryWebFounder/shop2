# ================================================================
# 환경변수 템플릿 (.env.local 로 복사 후 값 입력)
# ================================================================

# ── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 사이트 ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-shop.vercel.app
NEXT_PUBLIC_SITE_NAME=쇼핑몰

# ── Cron 보안 토큰 ────────────────────────────────────────────────
# openssl rand -hex 32 로 생성
CRON_SECRET=your-cron-secret-here

# ── 토스페이먼츠 ─────────────────────────────────────────────────
# https://developers.tosspayments.com 에서 발급
NEXT_PUBLIC_TOSS_CLIENT_KEY=ck_test_...
TOSS_SECRET_KEY=sk_test_...
TOSS_WEBHOOK_SECRET=your-webhook-secret

# ── Web Push (VAPID) ─────────────────────────────────────────────
# 생성: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:admin@your-shop.com
